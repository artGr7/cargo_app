<div class="container mt-5">
  <h1 class="mb-4 text-center">Добро пожаловать в CargoApp</h1>

  <% if user_signed_in? %>
    <div class="mb-4 text-center">
      <p>Здравствуйте, <strong><%= current_user.email %></strong>!</p>
      <%= link_to "Создать новую заявку", new_order_path, class: "btn btn-outline-secondary me-2" %>
      <%= link_to "Мои заявки", orders_path, class: "btn btn-outline-secondary" %>
    </div>

    <h2 class="mb-3">Ваши последние заявки:</h2>
    <div class="table-responsive">
      <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
          <tr>
            <th>Откуда</th>
            <th>Куда</th>
            <th>Цена</th>
            <th>Статус</th>
            <th>Создана</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr>
              <td><%= order.from %></td>
              <td><%= order.to %></td>
              <td><%= order.price %> ₽</td>
              <td><%= order.status %></td>
              <td><%= order.created_at.strftime("%d.%m.%Y %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info text-center mt-4">
      Чтобы оформить заявку, пожалуйста,
      <%= link_to "войдите", new_user_session_path, class: "btn btn-outline-primary btn-sm mx-1" %>
      или
      <%= link_to "зарегистрируйтесь", new_user_registration_path, class: "btn btn-outline-success btn-sm mx-1" %>.
    </div>
  <% end %>
</div>