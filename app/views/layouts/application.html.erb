<!DOCTYPE html>
<html>
  <!-- Bootstrap CSS CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <head>
    <title><%= content_for(:title) || "Cargo App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav style="background: #f8f9fa; padding: 1em; border-bottom: 1px solid #ddd; margin-bottom: 2em;">
      <div style="display: flex; justify-content: flex-end; align-items: center; gap: 1em;">
        <% if user_signed_in? %>
          <span>Привет, <strong><%= current_user.email %></strong></span>
          <%= link_to "Выйти", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-danger btn-sm" %>
        <% else %>
          <%= link_to "Вход", new_user_session_path, class: "btn btn-outline-primary btn-sm" %>
          <%= link_to "Регистрация", new_user_registration_path, class: "btn btn-outline-primary btn-sm" %>
        <% end %>
      </div>
    </nav>
    <%= yield %>
  </body>
</html>
